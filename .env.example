# =============================================
# Root-level .env cho docker-compose
# Sao chép thành .env và điền giá trị thực
# =============================================

# Ports (tùy chọn — có giá trị mặc định)
BACKEND_PORT=5001
FRONTEND_PORT=80
ADMINER_PORT=8080

# Database (dùng chung cho mysql service và backend)
DB_NAME=money_manager
DB_PASSWORD=your_db_password
